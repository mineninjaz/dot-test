<h1>Category List</h1>

<a href="/categories/create">
    Tambah Category
</a>

<hr>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Description</th>
        <th>Action</th>
    </tr>

    <% categories.forEach(category=> { %>

        <tr>
            <td>
                <%= category.id %>
            </td>
            <td>
                <%= category.name %>
            </td>
            <td>
                <%= category.description %>
            </td>
            <td>
                <a href="/categories/edit/<%= category.id %>">Edit</a>
                <a href="/categories/delete/<%= category.id %>" onclick="return confirm('Yakin mau hapus?')">
                    Delete
                </a>
            </td>
        </tr>

        <% }) %>

</table>