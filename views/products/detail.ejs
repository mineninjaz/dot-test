<h1>Product Detail</h1>

<table border="1" cellpadding="10">
    <tr>
        <th>ID</th>
        <td><%= product.id %></td>
    </tr>
    <tr>
        <th>Name</th>
        <td><%= product.name %></td>
    </tr>
    <tr>
        <th>Price</th>
        <td><%= product.price %></td>
    </tr>
    <tr>
        <th>Stock</th>
        <td><%= product.stock %></td>
    </tr>
    <tr>
        <th>Category</th>
        <td><%= product.category_name %></td>
    </tr>
</table>

<br>
<a href="/products">Back</a>
